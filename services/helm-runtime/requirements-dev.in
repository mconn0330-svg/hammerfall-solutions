# Dev-only deps source-of-truth (T0.A7).
# Pinned + hashed lockfile is requirements-dev.txt (generated by pip-compile).
#
# Workflow:
#   1. Edit this file (add/remove/bump top-level deps).
#   2. Run: pip-compile --generate-hashes -o requirements-dev.txt requirements-dev.in
#   3. Commit both. CI verifies they're in sync.
#
# Install for development:
#   pip install -r requirements.txt -r requirements-dev.txt

pytest==8.4.2
pytest-asyncio==1.3.0
pytest-cov==7.1.0

# Linters/formatters — match the pre-commit-pinned versions in /.pre-commit-config.yaml
# so local pre-commit and CI produce identical results.
ruff==0.15.12
black==26.3.1

# Type checker (T0.A5). Strict mode enforced via [tool.mypy] in pyproject.toml.
mypy==1.20.2
types-PyYAML==6.0.12.20260408

# Lockfile generator + check (T0.A7). pip-compile from this `.in` produces
# the hashed `.txt`. CI uses `pip-compile --check` to detect drift.
pip-tools==7.5.3
